#!/bin/sh

WHITE="/sys/class/leds/white:status/brightness"
RED="/sys/class/leds/red:power/brightness"
SELF_PIDFILE="/var/run/tunnel-on.pid"
VPS_WG_IP="10.66.0.1"
MAX_WAIT=300

# Register own PID so tunnel-off can interrupt us
echo $$ > "$SELF_PIDFILE"

logger -t tunnel-switch "Activating tunnel mode (pid=$$)"

# Tunnel ON indication: white ON, red OFF
echo 1 > "$WHITE"
echo 0 > "$RED"

# Start tunnel
/etc/init.d/vk-turn start 2>/dev/null
ifup wg0 2>/dev/null
sleep 2

# Restore route in wg table
ip route replace default dev wg0 table wg 2>/dev/null

# Add managed routing rules (700 + 750 always together)
ip rule show | grep -q "priority 700" || \
    ip rule add from 192.168.99.0/24 lookup wg priority 700
ip rule show | grep -q "priority 750" || \
    ip rule add from 192.168.99.0/24 unreachable priority 750

# DNS: switch to public resolvers
if ! uci get dhcp.@dnsmasq[0].server 2>/dev/null | grep -q "1.1.1.1"; then
    uci set dhcp.@dnsmasq[0].noresolv='1'
    uci del dhcp.@dnsmasq[0].server 2>/dev/null
    uci add_list dhcp.@dnsmasq[0].server='1.1.1.1'
    uci add_list dhcp.@dnsmasq[0].server='8.8.8.8'
    uci commit dhcp
    /etc/init.d/dnsmasq reload 2>/dev/null || /etc/init.d/dnsmasq restart
fi

# Wait for tunnel handshake
logger -t tunnel-switch "Waiting for tunnel (max ${MAX_WAIT}s)..."
elapsed=0
while [ $elapsed -lt $MAX_WAIT ]; do
    # Check if tunnel-off interrupted us
    if [ ! -f "$SELF_PIDFILE" ]; then
        logger -t tunnel-switch "Interrupted by tunnel-off - exiting"
        exit 0
    fi

    if ping -c1 -W2 -I wg0 "$VPS_WG_IP" > /dev/null 2>&1; then
        logger -t tunnel-switch "Tunnel up after ${elapsed}s"
        ip route flush cache
        rm -f "$SELF_PIDFILE"
        break
    fi
    sleep 2
    elapsed=$((elapsed + 2))
done

# Check if we were interrupted during sleep
if [ ! -f "$SELF_PIDFILE" ]; then
    logger -t tunnel-switch "Interrupted by tunnel-off during wait - exiting"
    exit 0
fi

if [ $elapsed -ge $MAX_WAIT ]; then
    logger -t tunnel-switch "WARNING: tunnel timeout after ${MAX_WAIT}s"
    rm -f "$SELF_PIDFILE"
    exit 0
fi

logger -t tunnel-switch "Tunnel mode ON"
