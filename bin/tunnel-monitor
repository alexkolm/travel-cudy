#!/bin/sh

PIDFILE="/var/run/tunnel-monitor.pid"
RED="/sys/class/leds/red:power/brightness"
VPS_WG_IP="10.66.0.1"
INTERVAL=10

echo $$ > "$PIDFILE"
logger -t tunnel-monitor "Started (pid=$$)"

while true; do
    if ping -c1 -W3 -I wg0 "$VPS_WG_IP" > /dev/null 2>&1; then
        echo 0 > "$RED"
    else
        echo 1 > "$RED"
        logger -t tunnel-monitor "Tunnel unreachable - red LED on"
    fi
    sleep "$INTERVAL"
done
